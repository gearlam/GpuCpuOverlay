<Window x:Class="GpuOverlay.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="GPU 温度"
        Width="Auto" Height="Auto"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        ResizeMode="NoResize"
        ShowInTaskbar="False"
        Topmost="True"
        SizeToContent="WidthAndHeight"
        UseLayoutRounding="True"
        SnapsToDevicePixels="True"
        TextOptions.TextFormattingMode="Display"
        MouseLeftButtonDown="Window_MouseLeftButtonDown"
        Loaded="Window_Loaded"
        Closing="Window_Closing">

    <Window.Resources>
        <Style x:Key="MenuItemStyle" TargetType="MenuItem">
            <Setter Property="Padding" Value="10,6"/>
            <Setter Property="FontSize" Value="12"/>
        </Style>
    </Window.Resources>

    <Grid>
        <Border x:Name="RootBorder"
                Background="#CC1E1E1E"
                CornerRadius="10"
                BorderBrush="#55333333"
                BorderThickness="1"
                Padding="14,10"
                SnapsToDevicePixels="True"
                HorizontalAlignment="Left"
                VerticalAlignment="Top">
            <Border.ContextMenu>
                <ContextMenu>
                    <MenuItem x:Name="MenuLock" Header="锁定位置" Click="MenuLock_Click" Style="{StaticResource MenuItemStyle}"/>
                    <Separator/>
                    <MenuItem Header="退出" Click="MenuExit_Click" Style="{StaticResource MenuItemStyle}"/>
                </ContextMenu>
            </Border.ContextMenu>
            <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                <!-- GPU -->
                <StackPanel Orientation="Vertical" VerticalAlignment="Center">
                    <TextBlock Text="GPU"
                               Foreground="#FF4FC3F7"
                               FontSize="13"
                               FontWeight="Bold"
                               HorizontalAlignment="Center"/>
                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                        <TextBlock x:Name="TextGpuTemp"
                                   Text="--"
                                   Foreground="White"
                                   FontSize="32"
                                   FontWeight="Bold"/>
                        <TextBlock Text="°"
                                  Foreground="#FFB0B0B0"
                                  FontSize="16"
                                  VerticalAlignment="Top"
                                  Margin="1,0,0,0"/>
                    </StackPanel>
                    <TextBlock x:Name="TextGpuUsage"
                               Text=""
                               Foreground="#FF80CBC4"
                               FontSize="11"
                               HorizontalAlignment="Center"/>
                </StackPanel>
                <!-- 分隔线 -->
                <Rectangle Width="1" Height="50"
                           Fill="#33FFFFFF"
                           Margin="12,0"/>
                <!-- CPU -->
                <StackPanel Orientation="Vertical" VerticalAlignment="Center">
                    <TextBlock Text="CPU"
                               Foreground="#FFCE93D8"
                               FontSize="13"
                               FontWeight="Bold"
                               HorizontalAlignment="Center"/>
                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                        <TextBlock x:Name="TextCpuTemp"
                                   Text="--"
                                   Foreground="White"
                                   FontSize="32"
                                   FontWeight="Bold"/>
                        <TextBlock Text="°"
                                  Foreground="#FFB0B0B0"
                                  FontSize="16"
                                  VerticalAlignment="Top"
                                  Margin="1,0,0,0"/>
                    </StackPanel>
                    <TextBlock x:Name="TextCpuInfo"
                               Text=""
                               Foreground="#FFCE93D8"
                               FontSize="11"
                               HorizontalAlignment="Center"/>
                </StackPanel>
            </StackPanel>
        </Border>
    </Grid>
</Window>
